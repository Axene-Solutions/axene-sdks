{
  "name": "@axene/mailer",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for Axene Mailer: send receipts, confirmations, and campaigns from your own domain. Priced in KES, billed via M-Pesa.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["email", "mailer", "axene", "africa", "kes", "mpesa", "transactional", "smtp", "api"],
  "homepage": "https://axene.io/docs/mailer/getting-started/welcome",
  "repository": { "type": "git", "url": "git+https://github.com/Axene-Solutions/axene-sdks.git", "directory": "packages/typescript" },
  "bugs": { "url": "https://github.com/Axene-Solutions/axene-sdks/issues" },
  "license": "MIT",
  "author": "Axene Solutions",
  "publishConfig": { "access": "public", "provenance": true },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
