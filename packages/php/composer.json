{
    "name": "axene/mailer",
    "description": "Official PHP SDK for the Axene Mailer API.",
    "type": "library",
    "license": "MIT",
    "keywords": ["axene", "mailer", "email", "sdk", "api"],
    "homepage": "https://mail.axene.io",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Axene\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Axene\\Mailer\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
