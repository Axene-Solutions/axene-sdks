# frozen_string_literal: true

require "rake/testtask"
require "bundler/gem_tasks"

Rake::TestTask.new(:test) do |t|
  t.libs << "test"
  t.libs << "lib"
  t.test_files = FileList["test/**/*_test.rb"]
  t.warning = false
end

# Releases are tagged externally (the `ruby-v*` tag in the axene-sdks monorepo),
# so the release task only builds the gem and pushes it to RubyGems. Bundler's
# default git steps (guard_clean, source_control_push) are intentionally skipped
# because there is no per-gem git repo to tag here.
Rake::Task["release"].clear
task release: ["build", "release:rubygem_push"]

task default: :test
